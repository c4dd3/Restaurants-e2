# =================================================================
# Restaurants-e2 — Variables de entorno
# Copiá este archivo a .env y ajustá los valores según tu entorno.
# =================================================================

# ------ Selector de motor de base de datos ------
# Valores válidos: postgres | mongo
DB_ENGINE=mongo

# ------ Postgres ------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=restaurants
# DSN completa (se arma a partir de las anteriores si queda vacía)
POSTGRES_DSN=

# ------ MongoDB (con sharding) ------
# El cliente se conecta al mongos (router), no directo a los shards
MONGO_URI=mongodb://mongos:27017/restaurants?replicaSet=&readPreference=primary
MONGO_DB=restaurants

# ------ Redis ------
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=300

# ------ ElasticSearch ------
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=products

# ------ Servicios ------
API_PORT=8080
AUTH_PORT=8081
SEARCH_PORT=8082

# ------ JWT (compartido entre auth y api) ------
JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres-random
JWT_TTL_HOURS=24

# ------ Logging ------
LOG_LEVEL=info
GIN_MODE=release

# ------ Seed (solo para go run ./scripts/seed) ------
ANTHROPIC_API_KEY=
SEED_LLM_MODEL=claude-haiku-4-5-20251001
